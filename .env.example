# Vizier MCP Server -- Environment Variables
# Copy to .env and fill in values.

# Required: Anthropic API key for Sentinel Haiku evaluator
ANTHROPIC_API_KEY=your-api-key-here

# Optional: Override the default data directory (default: /data/vizier)
# VIZIER_ROOT=/data/vizier

# Optional: Health endpoint port (default: 8080, auto-enabled in Docker)
# HEALTH_PORT=8080

# Required for OpenClaw/Telegram: bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Optional: Azure Key Vault URL for production secret management
# When set, ANTHROPIC_API_KEY is read from Key Vault instead of env vars.
# AZURE_KEY_VAULT_URL=https://vizier.vault.azure.net/
