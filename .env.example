# Vizier Environment Variables
# Copy this file to .env and fill in the values

# --- LLM Providers ---
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...                    # Optional: if using OpenAI models via LiteLLM

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...       # From @BotFather
TELEGRAM_SULTAN_CHAT_ID=123456789          # Sultan's Telegram user ID (for auth)

# --- Server Paths ---
VIZIER_HOME=/opt/vizier                    # Root directory for Vizier data
VIZIER_WORKSPACES_DIR=/opt/vizier/workspaces
VIZIER_REPORTS_DIR=/opt/vizier/reports
VIZIER_EA_DIR=/opt/vizier/ea

# --- Budget ---
VIZIER_MONTHLY_BUDGET_USD=100              # Monthly API spend limit (D33)

# --- Git ---
GIT_AUTHOR_NAME=Vizier
GIT_AUTHOR_EMAIL=vizier@localhost

# --- Optional: Calendar MCP ---
# GOOGLE_OAUTH_CLIENT_ID=...               # For workspace-mcp (Google Calendar)
# GOOGLE_OAUTH_CLIENT_SECRET=...
# MICROSOFT_CLIENT_ID=...                  # For Microsoft 365 MCP Server
# MICROSOFT_CLIENT_SECRET=...
# MICROSOFT_TENANT_ID=...
