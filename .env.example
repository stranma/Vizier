# Vizier + Hermes -- Environment Variables
# Copy to .env and fill in values.

# Required: Anthropic API key (used by Hermes for Vizier agent and by vizier-mcp for Sentinel)
ANTHROPIC_API_KEY=your-api-key-here

# Required for Telegram: bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Required for Telegram: Sultan's user ID (restricts bot access)
TELEGRAM_ALLOWED_USERS=your-telegram-user-id-here

# Optional: GitHub PAT for province-scoped repo access (later phases)
# GITHUB_TOKEN=your-github-pat-here

# Optional: Override the default data directory (default: /data/vizier)
# VIZIER_ROOT=/data/vizier

# Optional: Health endpoint port (default: 8080, auto-enabled in Docker)
# HEALTH_PORT=8080

# Optional: Azure Key Vault URL for production secret management
# AZURE_KEY_VAULT_URL=https://vizier.vault.azure.net/
