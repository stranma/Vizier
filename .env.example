# Vizier + Hermes -- Environment Variables
# Copy to .env and fill in values.

# ── Authentication ───────────────────────────────────────────────────────────
# Hermes supports two auth methods. Pick ONE:
#
# OPTION 1 (recommended): Subscription auth (Claude Max/Pro or GitHub Copilot)
#   1. Install Hermes locally: curl -fsSL https://raw.githubusercontent.com/NousResearch/hermes-agent/main/scripts/install.sh | bash
#   2. Run: hermes login           (for Anthropic subscription)
#      or:  hermes login copilot   (for GitHub Copilot subscription)
#   3. Copy ~/.hermes/auth.json to this project's hermes/auth.json
#   4. docker-compose mounts it automatically (no API key needed)
#
# OPTION 2: API key auth
#   Set ANTHROPIC_API_KEY below.
#
# For GitHub Copilot subscription (OpenAI models via Copilot):
#   Set COPILOT_GITHUB_TOKEN below AND change model.provider to "copilot"
#   in hermes/config.yaml.

# API key (only needed if NOT using subscription auth via auth.json)
# ANTHROPIC_API_KEY=your-api-key-here

# GitHub Copilot token (only needed for Copilot provider)
# COPILOT_GITHUB_TOKEN=your-copilot-token-here

# ── Telegram ─────────────────────────────────────────────────────────────────
# Required: bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Required: Sultan's Telegram user ID (restricts bot access)
# Get yours by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=your-telegram-user-id-here

# ── Optional ─────────────────────────────────────────────────────────────────
# GitHub PAT for province-scoped repo access (later phases)
# GITHUB_TOKEN=your-github-pat-here

# Override auth.json location (default: ./hermes/auth.json)
# HERMES_AUTH_JSON=/path/to/your/auth.json

# Override the default data directory (default: /data/vizier)
# VIZIER_ROOT=/data/vizier

# Infisical project/env for scripts/fetch-secrets.sh (optional)
# INFISICAL_PROJECT_SLUG=vizier
# INFISICAL_ENV_SLUG=prod
