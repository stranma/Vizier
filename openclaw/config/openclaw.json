{
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "pairing"
    }
  },
  "mcpServers": {
    "vizier": {
      "command": "docker",
      "args": ["exec", "-i", "vizier-mcp", "uv", "run", "--directory", "vizier-mcp", "python", "-m", "vizier_mcp.server"],
      "env": {
        "VIZIER_ROOT": "/data/vizier",
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}"
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace/vizier",
      "model": {
        "primary": "anthropic/claude-opus-4-6"
      }
    },
    "list": [
      {
        "id": "vizier",
        "default": true,
        "workspace": "/home/node/.openclaw/workspace/vizier",
        "model": "anthropic/claude-opus-4-6",
        "identity": {
          "name": "Vizier",
          "emoji": "👳"
        }
      }
    ]
  },
  "bindings": [
    {
      "agentId": "vizier",
      "match": {
        "channel": "telegram"
      }
    }
  ],
  "gateway": {
    "bind": "lan",
    "port": 18789
  }
}
